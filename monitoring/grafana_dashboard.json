{
  "dashboard": {
    "id": null,
    "uid": "disaster-triage-engine",
    "title": "Disaster Triage Engine — Model Performance",
    "description": "Real-time monitoring of ML inference, feed ingestion, and model accuracy for the Disaster Triage Engine.",
    "tags": ["disaster-triage", "ml-ops", "rapid-alert"],
    "timezone": "browser",
    "refresh": "10s",
    "schemaVersion": 39,
    "version": 1,
    "panels": [
      {
        "id": 1,
        "title": "Prediction Latency (p50 / p95 / p99)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
        "targets": [
          {
            "expr": "histogram_quantile(0.50, rate(triage_prediction_latency_ms_bucket[5m]))",
            "legendFormat": "p50"
          },
          {
            "expr": "histogram_quantile(0.95, rate(triage_prediction_latency_ms_bucket[5m]))",
            "legendFormat": "p95"
          },
          {
            "expr": "histogram_quantile(0.99, rate(triage_prediction_latency_ms_bucket[5m]))",
            "legendFormat": "p99"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ms",
            "thresholds": {
              "steps": [
                { "color": "green", "value": null },
                { "color": "yellow", "value": 50 },
                { "color": "red", "value": 200 }
              ]
            }
          }
        }
      },
      {
        "id": 2,
        "title": "Predictions per Second",
        "type": "stat",
        "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
        "targets": [
          {
            "expr": "rate(triage_predictions_total[1m])",
            "legendFormat": "pred/s"
          }
        ],
        "fieldConfig": {
          "defaults": { "unit": "reqps" }
        }
      },
      {
        "id": 3,
        "title": "Severity Distribution",
        "type": "piechart",
        "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
        "targets": [
          {
            "expr": "triage_predictions_by_severity_total",
            "legendFormat": "{{severity}}"
          }
        ]
      },
      {
        "id": 4,
        "title": "Feed Ingestion Rate",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
        "targets": [
          {
            "expr": "rate(triage_feed_events_ingested_total[5m])",
            "legendFormat": "events/s"
          },
          {
            "expr": "rate(triage_feed_errors_total[5m])",
            "legendFormat": "errors/s"
          }
        ],
        "fieldConfig": {
          "defaults": { "unit": "short" }
        }
      },
      {
        "id": 5,
        "title": "Model Accuracy (Severity Classifier)",
        "type": "gauge",
        "gridPos": { "h": 8, "w": 6, "x": 12, "y": 8 },
        "targets": [
          {
            "expr": "triage_model_accuracy",
            "legendFormat": "accuracy"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "min": 0,
            "max": 1,
            "thresholds": {
              "steps": [
                { "color": "red", "value": null },
                { "color": "yellow", "value": 0.80 },
                { "color": "green", "value": 0.90 }
              ]
            }
          }
        }
      },
      {
        "id": 6,
        "title": "Escalation AUC-ROC",
        "type": "gauge",
        "gridPos": { "h": 8, "w": 6, "x": 18, "y": 8 },
        "targets": [
          {
            "expr": "triage_escalation_auc_roc",
            "legendFormat": "AUC-ROC"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "min": 0,
            "max": 1,
            "thresholds": {
              "steps": [
                { "color": "red", "value": null },
                { "color": "yellow", "value": 0.85 },
                { "color": "green", "value": 0.92 }
              ]
            }
          }
        }
      },
      {
        "id": 7,
        "title": "Classifier vs Escalation Latency",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(triage_classifier_latency_ms_bucket[5m]))",
            "legendFormat": "Classifier p95"
          },
          {
            "expr": "histogram_quantile(0.95, rate(triage_escalation_latency_ms_bucket[5m]))",
            "legendFormat": "Escalation p95"
          }
        ],
        "fieldConfig": {
          "defaults": { "unit": "ms" }
        }
      },
      {
        "id": 8,
        "title": "Active Data Feeds",
        "type": "stat",
        "gridPos": { "h": 8, "w": 6, "x": 12, "y": 16 },
        "targets": [
          {
            "expr": "triage_active_feeds",
            "legendFormat": "feeds"
          }
        ]
      }
    ],
    "templating": {
      "list": []
    },
    "time": { "from": "now-1h", "to": "now" }
  }
}
